{
    "editor.accessibilitySupport": "off",
    "editor.codeActionsOnSave": {
        "source.organizeImports": true
    },
    "editor.codeLens": false,
    "editor.comments.insertSpace": false,
    "editor.copyWithSyntaxHighlighting": false,
    "editor.fontLigatures": true,
    "editor.dragAndDrop": false,
    "editor.fontFamily": "JetBrains Mono Light",
    "editor.fontSize": 12,
    "editor.formatOnSave": true,
    "editor.links": false,
    "editor.maxTokenizationLineLength": 2000,
    "editor.minimap.enabled": false,
    "editor.semanticHighlighting.enabled": true,
    "explorer.confirmDelete": false,
    "files.hotExit": "off",
    "files.insertFinalNewline": true,
    "files.participants.timeout": 0,
    "files.restoreUndoStack": false,
    "gopls": {
        "analyses": {
            "asmdecl": false,
            "assign": true,
            "atomic": true,
            "atomicalign": true,
            "bools": true,
            "buildtag": true,
            "cgocall": true,
            "composites": true,
            "copylocks": true,
            "deepequalerrors": true,
            "errorsas": true,
            "fieldalignment": true,
            "httpresponse": true,
            "ifaceassert": true,
            "infertypeargs": true,
            "loopclosure": true,
            "lostcancel": true,
            "nilfunc": true,
            "nilness": true,
            "printf": true,
            "shadow": true,
            "shift": true,
            "simplifycompositelit": true,
            "simplifyrange": true,
            "simplifyslice": true,
            "sortslice": true,
            "stdmethods": true,
            "stringintconv": true,
            "structtag": true,
            "testinggoroutine": true,
            "tests": true,
            "unmarshal": true,
            "unreachable": true,
            "unsafeptr": false,
            "unusedparams": true,
            "unusedresult": true,
            "unusedwrite": true,
            "useany": true,
            "fillreturns": true,
            "nonewvars": true,
            "noresultvalues": true,
            "undeclaredname": true,
            "fillstruct": true,
            "stubmethods": true,
        },
        "gofumpt": true,
        "semanticTokens": true,
        "usePlaceholders": true
    },
    "security.workspace.trust.enabled": false,
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.customGlyphs": false,
    "terminal.integrated.fontSize": 12,
    "workbench.editor.enablePreview": false,
    "workbench.startupEditor": "none",
    "workbench.welcomePage.walkthroughs.openOnInstall": false,
    "editor.suggest.snippetsPreventQuickSuggestions": false,
    "editor.autoIndent": "advanced",
    "editor.occurrencesHighlight": false,
    "editor.selectionHighlight": false,
    "files.trimTrailingWhitespace": true,
    "files.trimFinalNewlines": true,
    "[go]": {
        "files.trimTrailingWhitespace": false,
        "files.trimFinalNewlines": false,
    },
    "intelephense.diagnostics.run": "onSave",
    "intelephense.environment.phpVersion": "8.1.4",
    "intelephense.format.enable": false,
    "explorer.autoReveal": false,
    "clangd.fallbackFlags": [
        "-std=c11"
    ],
    "editor.formatOnSaveMode": "modificationsIfAvailable",
    "html.format.endWithNewline": true,
    "php-cs-fixer.formatHtml": true,
    "php-cs-fixer.lastDownload": 0,
    "php-cs-fixer.onsave": true,
    "php.validate.executablePath": "/usr/bin/php",
    "php-cs-fixer.allowRisky": true,
    "php-cs-fixer.executablePath": "php-cs-fixer",
    "workbench.tree.expandMode": "doubleClick",
    "editor.multiCursorModifier": "ctrlCmd",
    "workbench.colorTheme": "Gruvbox Dark Hard",
    "svelte.plugin.svelte.format.config.singleQuote": true,
    "svelte.plugin.svelte.format.config.svelteStrictMode": true,
    "svelte.enable-ts-plugin": true,
    "php.suggest.basic": false,
    "intelephense.phpdoc.returnVoid": false,
    "intelephense.phpdoc.textFormat": "text",
    "html.format.templating": true,
}
