{
    "editor.accessibilitySupport": "off",
    "editor.codeActionsOnSave": {
        "source.organizeImports": true
    },
    "editor.codeLens": false,
    "editor.comments.insertSpace": false,
    "editor.copyWithSyntaxHighlighting": false,
    "editor.fontLigatures": true,
    "editor.dragAndDrop": false,
    "editor.fontFamily": "JetBrains Mono Light",
    "editor.fontSize": 12,
    "editor.formatOnSave": true,
    "editor.links": false,
    "editor.maxTokenizationLineLength": 2000,
    "editor.minimap.enabled": false,
    "editor.semanticHighlighting.enabled": true,
    "explorer.confirmDelete": false,
    "files.hotExit": "off",
    "files.insertFinalNewline": true,
    "files.participants.timeout": 0,
    "files.restoreUndoStack": false,
    "gopls": {
        "analyses": {
            "asmdecl": false,
            "assign": true,
            "atomic": true,
            "atomicalign": true,
            "bools": true,
            "buildtag": true,
            "cgocall": true,
            "composites": true,
            "copylocks": true,
            "deepequalerrors": false,
            "errorsas": true,
            "fieldalignment": true,
            "fillreturns": true,
            "fillstruct": true,
            "httpresponse": true,
            "ifaceassert": true,
            "infertypeargs": true,
            "loopclosure": true,
            "lostcancel": true,
            "nilfunc": true,
            "nilness": true,
            "nonewvars": true,
            "noresultvalues": true,
            "printf": true,
            "shadow": true,
            "shift": true,
            "simplifycompositelit": true,
            "simplifyrange": true,
            "simplifyslice": true,
            "sortslice": true,
            "stdmethods": true,
            "stringintconv": true,
            "structtag": true,
            "testinggoroutine": true,
            "tests": true,
            "undeclaredname": true,
            "unmarshal": true,
            "unreachable": true,
            "unsafeptr": true,
            "unusedparams": true,
            "unusedresult": true,
            "unusedwrite": true,
            "useany": true
        },
        "gofumpt": true,
        "semanticTokens": true,
        "usePlaceholders": true
    },
    "security.workspace.trust.enabled": false,
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.customGlyphs": false,
    "terminal.integrated.fontSize": 12,
    "workbench.editor.enablePreview": false,
    "workbench.startupEditor": "none",
    "workbench.welcomePage.walkthroughs.openOnInstall": false,
    "go.useCodeSnippetsOnFunctionSuggest": true,
    "go.useCodeSnippetsOnFunctionSuggestWithoutType": true,
    "editor.suggest.showSnippets": false,
    "editor.suggest.snippetsPreventQuickSuggestions": false,
    "editor.snippetSuggestions": "none",
    "editor.autoIndent": "advanced",
    "editor.occurrencesHighlight": false,
    "editor.selectionHighlight": false,
    "files.trimTrailingWhitespace": true,
    "files.trimFinalNewlines": true,
    "[go]": {
        "files.trimTrailingWhitespace": false,
        "files.trimFinalNewlines": false,
    },
    "intelephense.diagnostics.run": "onSave",
    "intelephense.environment.phpVersion": "7.4.27",
    "intelephense.format.enable": false,
    "explorer.autoReveal": false,
    "simple-php-cs-fixer.config": ".php-cs-fixer.php",
    "simple-php-cs-fixer.save": true,
    "simple-php-cs-fixer.useConfig": true,
    "simple-php-cs-fixer.usingCache": true,
    "clangd.fallbackFlags": [
        "-std=c11"
    ],
    "workbench.colorTheme": "semantic-rainbow",
    "workbench.iconTheme": "vs-minimal",
    "editor.formatOnSaveMode": "modificationsIfAvailable",
    "html.format.endWithNewline": true,
    "php-cs-fixer.autoFixBySemicolon": true,
    "php-cs-fixer.formatHtml": true,
    "php-cs-fixer.lastDownload": 0,
    "php-cs-fixer.onsave": true,
}
